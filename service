#!/usr/bin/env bash
# service — single-file CLI for the holistic `notify` service (platform-wide notification
# interface). Owns install/repair (`setup`) and lifecycle. The systemd unit, Caddy route and the
# rights drop-in are generated inline by `setup` — this script is their source of truth.
#
# notify has NO dashboard tab of its own: its UI is the notification centre the shell renders in
# the top bar (shipped in @holistic/ui + the app shell). So `setup` links no UI plugin and does
# not rebuild the SPA — it only wires the daemon, the Caddy route, the rights and the shared
# emit secret. The service id is auto-detected from permissions/<id>.json.

set -euo pipefail

TEMPLATE_VERSION="0.1.0"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORIG_ARGS=("$@")

detect_service_id() {
  local f
  for f in "$REPO_ROOT"/permissions/*.json; do
    [ -e "$f" ] || continue
    basename "$f" .json
    return 0
  done
  return 1
}
: "${SERVICE_ID:=}"
[ -n "$SERVICE_ID" ] || SERVICE_ID="$(detect_service_id || true)"

# ── config (override via env) ─────────────────────────────────────────────────────
: "${SERVICE_APP:=/opt/${SERVICE_ID:-notify}}"
: "${SERVICE_USER:=${SERVICE_ID:-notify}}"
: "${SERVICE_PORT:=8778}"
: "${SERVICE_ADMIN_GROUP:=sudo}"
: "${HOLISTIC_SECRET_FILE:=/etc/holistic/jwt-secret}"
: "${HOLISTIC_GROUP:=holistic}"
# Shared machine-to-machine emit secret. Group-readable so ANY holistic service daemon (all are in
# the holistic group) can post notifications on a user's behalf — exactly the intent.
: "${NOTIFY_SECRET_FILE:=/etc/holistic/notify-secret}"

# ── derived paths ──────────────────────────────────────────────────────────────────
UNIT="/etc/systemd/system/${SERVICE_ID}.service"
CADDY_ROUTE="/etc/caddy/conf.d/${SERVICE_ID}.caddy"
PERMS_FILE="/etc/holistic/permissions.d/${SERVICE_ID}.json"
DAEMON_BIN="$SERVICE_APP/bin/${SERVICE_ID}d"
ADMIN_ENV="$(printf '%s' "${SERVICE_ID:-notify}" | tr '[:lower:]' '[:upper:]')_ADMIN_GROUP"

log()  { [ "${SERVICE_QUIET:-0}" = "1" ] || printf '[%s] %s\n' "${SERVICE_ID:-notify}" "$*"; }
warn() { printf '[%s] warning: %s\n' "${SERVICE_ID:-notify}" "$*" >&2; }
die()  { printf '[%s] error: %s\n' "${SERVICE_ID:-notify}" "$*" >&2; exit "${2:-1}"; }

confirm() {
  [ "${SERVICE_YES:-0}" = "1" ] && return 0
  local reply
  printf '[%s] %s [y/N] ' "${SERVICE_ID:-notify}" "$1" >&2
  read -r reply || return 1
  [[ "$reply" =~ ^[yY]$ ]]
}

needs_root() {
  [ "$(id -u)" -eq 0 ] && return 0
  command -v sudo >/dev/null || die "must run as root (sudo not found)"
  exec sudo -E "$0" "${ORIG_ARGS[@]}"
}

require_id() { [ -n "$SERVICE_ID" ] || die "no permissions/<id>.json found — run from the repo root" 5; }

# ── build ───────────────────────────────────────────────────────────────────────
ensure_go() {
  command -v go >/dev/null && return 0
  log "installing Go toolchain..."
  apt-get update -qq
  apt-get install -y -qq golang-go >/dev/null
  command -v go >/dev/null || die "Go install failed" 4
}

build_daemon() {
  ensure_go
  log "building ${SERVICE_ID}d..."
  install -d -o "$SERVICE_USER" -g "$SERVICE_USER" -m 0755 "$SERVICE_APP" "$SERVICE_APP/bin"
  ( cd "$REPO_ROOT/backend" && GOCACHE="/tmp/${SERVICE_ID}-gocache" go build -o "$DAEMON_BIN" "./cmd/${SERVICE_ID}d" )
  chown -R "$SERVICE_USER:$SERVICE_USER" "$SERVICE_APP"
}

# ── inline artifact generators ─────────────────────────────────────────────────────
write_unit() {
  cat > "$UNIT" <<EOF
[Unit]
Description=${SERVICE_ID} — holistic notification service
After=network.target holistic-dashboard.service

[Service]
User=$SERVICE_USER
Group=$SERVICE_USER
# Validate the same session as the dashboard via the shared JWT secret.
Environment=HOLISTIC_SECRET_FILE=$HOLISTIC_SECRET_FILE
# Admin = single Linux source of truth (the sudo group by default).
Environment=$ADMIN_ENV=$SERVICE_ADMIN_GROUP
# Notification store (SQLite index) root.
Environment=NOTIFY_DATA=/var/lib/$SERVICE_ID
# Shared secret guarding POST internal/emit (machine-to-machine; provisioned by setup).
Environment=NOTIFY_INTERNAL_SECRET_FILE=$NOTIFY_SECRET_FILE
# Linux group enumerating all users, for admin broadcast (default smbusers).
Environment=NOTIFY_ENUM_GROUP=smbusers
ExecStart=$DAEMON_BIN --listen 127.0.0.1:$SERVICE_PORT
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=true
RestrictRealtime=true
# The derived SQLite index lives here (writable despite ProtectSystem=strict).
ReadWritePaths=/var/lib/$SERVICE_ID

[Install]
WantedBy=multi-user.target
EOF
}

write_caddy_route() {
  install -d /etc/caddy/conf.d
  cat > "$CADDY_ROUTE" <<EOF
# Generated by \`service setup\`. Routes the notify API to the Go daemon. Imported by holistic's
# Caddyfile. Caddy matches this more-specific path (/api/services/$SERVICE_ID/*) before the
# generic /api/* handler regardless of import order, so it wins.
handle /api/services/$SERVICE_ID/* {
	reverse_proxy 127.0.0.1:$SERVICE_PORT {
		# Server-Sent Events: stream live notifications to the open UI without buffering.
		flush_interval -1
	}
}
EOF
}

reload_caddy() {
  command -v caddy >/dev/null && [ -f /etc/caddy/Caddyfile ] || { warn "caddy not found — reload it manually to pick up the route"; return 0; }
  if ! grep -q 'conf.d' /etc/caddy/Caddyfile; then
    warn "/etc/caddy/Caddyfile does not import conf.d/*.caddy — the notify route will not load until it does"
  fi
  systemctl reload caddy 2>/dev/null || systemctl restart caddy 2>/dev/null || warn "could not reload caddy — do it manually"
}

declared_groups() {
  local src="$REPO_ROOT/permissions/$SERVICE_ID.json"
  [ -f "$src" ] || return 0
  grep -oE '"group"[[:space:]]*:[[:space:]]*"hp_[a-z0-9_-]+"' "$src" | grep -oE 'hp_[a-z0-9_-]+'
}

install_permissions() {
  local src="$REPO_ROOT/permissions/$SERVICE_ID.json"
  [ -f "$src" ] || die "missing $src" 5
  install -d -o "$HOLISTIC_GROUP" -g "$HOLISTIC_GROUP" -m 0755 /etc/holistic/permissions.d 2>/dev/null \
    || install -d -m 0755 /etc/holistic/permissions.d
  install -m 0644 "$src" "$PERMS_FILE"
  local g
  for g in $(declared_groups); do groupadd -f "$g"; done
}

grant_secret_access() {
  if [ ! -f "$HOLISTIC_SECRET_FILE" ]; then
    warn "$HOLISTIC_SECRET_FILE not found — install the holistic dashboard first"; return 0
  fi
  getent group "$HOLISTIC_GROUP" >/dev/null || die "group '$HOLISTIC_GROUP' missing — install the dashboard first" 5
  usermod -aG "$HOLISTIC_GROUP" "$SERVICE_USER"
  chgrp "$HOLISTIC_GROUP" "$HOLISTIC_SECRET_FILE"
  chmod 0640 "$HOLISTIC_SECRET_FILE"
}

# Provision the shared emit secret. Group-readable by the holistic group so every service daemon
# (icaly, mail, …) can POST notifications on a user's behalf. Idempotent.
provision_notify_secret() {
  getent group "$HOLISTIC_GROUP" >/dev/null || { warn "group '$HOLISTIC_GROUP' missing — skipping notify secret"; return 0; }
  command -v openssl >/dev/null || { warn "openssl not found — skipping notify secret"; return 0; }
  [ -f "$NOTIFY_SECRET_FILE" ] || ( umask 077; openssl rand -hex 32 > "$NOTIFY_SECRET_FILE" )
  chgrp "$HOLISTIC_GROUP" "$NOTIFY_SECRET_FILE" 2>/dev/null || true
  chmod 0640 "$NOTIFY_SECRET_FILE"
}

# ── commands ────────────────────────────────────────────────────────────────────────
cmd_setup() {
  require_id
  needs_root

  log "system user + directories..."
  getent group "$SERVICE_USER" >/dev/null || groupadd --system "$SERVICE_USER"
  getent passwd "$SERVICE_USER" >/dev/null \
    || useradd --system --gid "$SERVICE_USER" --shell /usr/sbin/nologin --home-dir "/var/lib/$SERVICE_ID" "$SERVICE_USER"
  install -d -o "$SERVICE_USER" -g "$SERVICE_USER" -m 0755 "$SERVICE_APP" "$SERVICE_APP/bin" "/var/lib/$SERVICE_ID"

  build_daemon

  log "granting read on the shared JWT secret..."
  grant_secret_access

  log "provisioning the shared emit secret ($NOTIFY_SECRET_FILE)..."
  provision_notify_secret

  log "configuring systemd..."
  write_unit
  systemctl daemon-reload
  systemctl enable "$SERVICE_ID" >/dev/null 2>&1 || true

  log "adding Caddy route + reloading Caddy..."
  write_caddy_route
  reload_caddy

  log "declaring rights (permissions.d) + backing groups..."
  install_permissions

  systemctl restart "$SERVICE_ID"
  if ! systemctl is-active --quiet "$SERVICE_ID"; then
    journalctl -u "$SERVICE_ID" -n 20 --no-pager >&2 || true
    die "$SERVICE_ID failed to start" 4
  fi
  log "installed and started — notifications are live in the holistic top bar"
  log "note: rebuild/redeploy the dashboard SPA to ship the notification centre UI (@holistic/ui + app shell)"
}

cmd_build() {
  require_id
  needs_root
  build_daemon
  if systemctl is-active --quiet "$SERVICE_ID"; then
    systemctl restart "$SERVICE_ID"; log "rebuilt and restarted ${SERVICE_ID}d"
  else
    log "rebuilt ${SERVICE_ID}d (service not running)"
  fi
}

cmd_lifecycle() {
  require_id; needs_root
  local action="$1"
  systemctl "$action" "$SERVICE_ID" && log "$action: $SERVICE_ID" \
    || die "'$action $SERVICE_ID' failed — installed? run 'sudo $0 setup'"
}

cmd_update() {
  require_id
  log "pulling latest..."
  git -C "$REPO_ROOT" pull --ff-only
  cmd_setup
}

cmd_status() {
  require_id
  local state; state="$(systemctl is-active "$SERVICE_ID" 2>/dev/null || true)"
  echo "── $SERVICE_ID (holistic notification service $TEMPLATE_VERSION) ──"
  printf '  %-16s %s\n' "daemon:" "${state:-unknown}"
  printf '  %-16s %s\n' "listen:" "127.0.0.1:$SERVICE_PORT"
  printf '  %-16s %s\n' "binary:" "$([ -x "$DAEMON_BIN" ] && echo "$DAEMON_BIN" || echo '(not built)')"
  printf '  %-16s %s\n' "unit:"   "$([ -f "$UNIT" ] && echo "$UNIT" || echo missing)"
  printf '  %-16s %s\n' "route:"  "$([ -f "$CADDY_ROUTE" ] && echo "$CADDY_ROUTE" || echo missing)"
  printf '  %-16s %s\n' "rights:" "$([ -f "$PERMS_FILE" ] && echo "$PERMS_FILE" || echo missing)"
  printf '  %-16s %s\n' "secret:" "$([ -f "$NOTIFY_SECRET_FILE" ] && echo "$NOTIFY_SECRET_FILE" || echo missing)"
  if command -v systemctl >/dev/null && [ -f "$UNIT" ]; then
    echo; echo "── systemctl status $SERVICE_ID ──"
    systemctl --no-pager --lines=3 status "$SERVICE_ID" 2>&1 || true
  fi
}

cmd_uninstall() {
  require_id; needs_root
  local purge=0
  [ "${1:-}" = "--purge" ] && purge=1
  confirm "remove $SERVICE_ID from this server${purge:+ (and purge user + $SERVICE_APP)}?" || die "aborted" 10
  systemctl disable --now "$SERVICE_ID" >/dev/null 2>&1 || true
  rm -f "$UNIT"; systemctl daemon-reload
  rm -f "$CADDY_ROUTE" "$PERMS_FILE"; reload_caddy
  if [ "$purge" = "1" ]; then
    userdel "$SERVICE_USER" >/dev/null 2>&1 || true
    groupdel "$SERVICE_USER" >/dev/null 2>&1 || true
    local g; for g in $(declared_groups); do groupdel "$g" >/dev/null 2>&1 || true; done
    rm -rf "$SERVICE_APP" "/var/lib/$SERVICE_ID"
    log "purged user, rights groups, $SERVICE_APP, /var/lib/$SERVICE_ID (kept $NOTIFY_SECRET_FILE — shared)"
  fi
  log "uninstalled"
}

cmd_help() {
  cat <<EOF
service — CLI for the holistic notify service ($TEMPLATE_VERSION).

Usage:
  sudo ./service setup            Install/repair: build the daemon, wire systemd + Caddy, declare
                                  rights, provision the shared emit secret. Self-elevates via sudo.
  sudo ./service build            Rebuild the Go daemon only, then restart if running
  sudo ./service start|stop|restart   Control the daemon
  ./service status                Show daemon, route, rights and secret health
  sudo ./service update           git pull --ff-only + re-run setup
  sudo ./service uninstall [--purge]  Remove (--purge also drops the user + $SERVICE_APP)
  ./service help | version

Notes:
  notify has no sidebar tab: its UI is the top-bar notification centre in the dashboard SPA
  (@holistic/ui + app shell). After 'setup', (re)build and deploy the SPA to ship that UI.
EOF
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    setup)                cmd_setup "$@" ;;
    build)                cmd_build "$@" ;;
    start|stop|restart)   cmd_lifecycle "$cmd" ;;
    status)               cmd_status "$@" ;;
    update)               cmd_update "$@" ;;
    uninstall)            cmd_uninstall "$@" ;;
    version|-v|--version) echo "holistic notify $TEMPLATE_VERSION" ;;
    help|-h|--help)       cmd_help ;;
    *) die "unknown command: $cmd (run './service help')" 2 ;;
  esac
}

main "$@"
